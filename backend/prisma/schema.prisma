generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int     @id @default(autoincrement())
  name         String?
  email        String?
  passwordHash String?
  role         String?

  @@map("users")
}

model Employee {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  department String?
  floor      Int?
  room       Int?

  @@map("employees")
}

model Technician {
  id                  Int     @id @default(autoincrement())
  userId              Int     @unique
  specializations     String?
  skillLevel          Int?
  experienceYears     Int?
  currentStatus       String?
  currentLoadMinutes  Int?
  activeTasksCount    Int?
  maxDailyLoadMinutes Int?
  currentDepartment   String?

  @@map("technicians")
}

model InitialRepairRequest {
  id         Int     @id @default(autoincrement())
  department String?
  floor      Int?
  room       Int?
  workImpact String? @map("workImpact")

  @@map("initial_repair_requests")
}

model AssignedRepairTask {
  id                     Int     @id @default(autoincrement())
  originalRequestId      Int     @unique @map(" originalRequestId")
  department             String?
  floor                  Int?
  room                   Int?
  faultTypeCode          String? @map("faultTypeCode")
  category               String?
  complexityLevel        Int?    @map("complexityLevel")
  estimatedRepairMinutes Int?    @map("estimatedRepairMinutes")
  priority               String?
  assignedTechnicianId   Int?    @map("assignedTechnicianId")
  createdAt              Int?    @map("createdAt")
  startedAt              String? @map("startedAt")
  status                 String?

  @@map("assigned_repair_tasks")
}
