generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int    @id @default(autoincrement())
  name         String
  email        String @unique
  passwordHash String
  role         String

  employee   Employee?
  technician Technician?

  @@map("users")
}

model Employee {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  department String?
  floor      Int?
  room       Int?

  user User @relation(fields: [userId], references: [id])

  @@map("employees")
}

model Technician {
  id                  Int     @id @default(autoincrement())
  userId              Int     @unique
  specializations     String?
  skillLevel          Int?
  experienceYears     Int?
  currentStatus       String?
  currentLoadMinutes  Int?
  activeTasksCount    Int?
  maxDailyLoadMinutes Int?
  currentDepartment   String?

  user User @relation(fields: [userId], references: [id])

  @@map("technicians")
}

model Testing {
  id   Int    @id @default(autoincrement())
  name String @map("Name")

  @@map("test")
}
model InitialRepairRequest {
  id         Int    @id @default(autoincrement())
  department String
  floor      Int
  room       Int
  workImpact String @map("workImpact")

  @@map("initial_repair_requests")
}